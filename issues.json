    {
        "title": "Intermittent Connectivity to File Server",
        "category": "Network",
        "severity": "Medium",
        "tags": [
            "latency",
            "packet loss",
            "switch-port",
            "cabling",
            "network-performance"
        ],
        "symptoms": [
            "Users report slow access to shared files",
            "Occasional \u201cnetwork path not found\u201d errors",
            "Ping to the file server shows intermittent packet loss (10\u201320%)",
            "Traceroute shows increased latency at one hop",
            "Only users on one floor/department are affected"
        ],
        "causes": [
            "Faulty Ethernet cable or damaged patch panel port",
            "Failing switch port causing intermittent drops",
            "Duplex mismatch between switch and workstation",
            "High utilization on the switch due to a broadcast storm",
            "Misconfigured VLAN assignment"
        ],
        "steps": [
            "Verified user reports and reproduced the issue with ping and traceroute",
            "Checked switch logs for errors (CRC errors, collisions, port flaps)",
            "Tested the affected workstation\u2019s port with a known\u2011good cable",
            "Moved the workstation to a different switch port to isolate the issue",
            "Confirmed correct VLAN assignment on the switch",
            "Monitored switch interface statistics for packet drops and errors",
            "Identified a high number of CRC errors on the original switch port",
            "Replaced the faulty switch port and retested connectivity"
        ]
    }
